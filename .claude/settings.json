{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(curl *)",

      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.envrc)",
      "Read(./secrets/**)",

      "Read(./configuration.*)",

      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/*.crt)",
      "Read(**/*.cer)",
      "Read(**/*.der)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*.p8)",
      "Read(**/*.ppk)",
      "Read(**/*.pub)",
      "Read(**/*.rsa)",

      "Read(**/id_rsa)",
      "Read(**/id_dsa)",
      "Read(**/id_ecdsa)",
      "Read(**/id_ed25519)",
      "Read(**/.ssh/**)",

      "Read(**/.npmrc)",
      "Read(**/auth.json)",
      "Read(**/.netrc)",

      "Read(**/values*.yaml)",
      "Read(**/docker-compose*.yml)",
      "Read(**/compose*.yml)",
      "Read(**/docker*.yml)",
      "Read(**/Dockerfile)",
      "Read(**/vault.yml)",

      "Read(./.htaccess)",
      "Read(*.sql)",
      "Read(*.zip)"
    ]
  }
}